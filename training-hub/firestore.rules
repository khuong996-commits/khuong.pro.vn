rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /whitelist/{email} {
      // Mọi user đã đăng nhập Google đều được đọc whitelist
      // (App nội bộ — cần check email có trong danh sách không)
      allow read: if request.auth != null;
      
      // Admin: toàn quyền ghi
      allow write: if request.auth != null 
        && request.auth.token.email == 'ih.khuongtrinh@gmail.com';
      
      // Leader: thêm/sửa member mới (role phải là 'member')
      allow create, update: if request.auth != null
        && exists(/databases/$(database)/documents/whitelist/$(request.auth.token.email))
        && get(/databases/$(database)/documents/whitelist/$(request.auth.token.email)).data.role == 'leader'
        && request.resource.data.role == 'member';
      
      // Leader: xóa member (chỉ xóa doc có role 'member')
      allow delete: if request.auth != null
        && exists(/databases/$(database)/documents/whitelist/$(request.auth.token.email))
        && get(/databases/$(database)/documents/whitelist/$(request.auth.token.email)).data.role == 'leader'
        && resource.data.role == 'member';
    }

    match /profiles/{email} {
      // User đọc/ghi profile của chính mình
      allow read, write: if request.auth != null 
        && request.auth.token.email == email;
      
      // Admin: đọc/ghi tất cả profiles
      allow read, write: if request.auth != null 
        && request.auth.token.email == 'ih.khuongtrinh@gmail.com';
      
      // Leader: đọc/ghi profiles của team
      allow read, write: if request.auth != null 
        && exists(/databases/$(database)/documents/whitelist/$(request.auth.token.email))
        && get(/databases/$(database)/documents/whitelist/$(request.auth.token.email)).data.role == 'leader';
    }
  }
}
